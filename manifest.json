{
  "manifest_version": 2,
  "name": "Twitter no ID verification",
  "version": "0.0.1",

  "browser_specific_settings": {
    "gecko": {
      "id": "twitter_no_id_verification@averi.me",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": ["webRequest", "webRequestBlocking", "*://x.com/*"],
  "background": { "scripts": ["background.js"] }
}
